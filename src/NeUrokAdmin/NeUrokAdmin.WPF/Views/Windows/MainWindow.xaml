<Window x:Class="NeUrokAdmin.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF"
        Loaded="Window_Loaded"
        Title="Главная">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="{StaticResource DarkPinkBg}">
            <TextBlock Text="НЕурОК: Админ панель" FontSize="20" Foreground="White" FontFamily="Calibri" Margin="30 20" FontWeight="Bold" />

            <ItemsControl ItemsSource="{Binding SideMenuItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="42" Cursor="Hand" Background="{StaticResource DarkPinkBg}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                      Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                      CommandParameter="{Binding}" />
                            </Border.InputBindings>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="8,0,0,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource LightYellow}"/>
                                            <Setter Property="Background" Value="{StaticResource VeryDarkPinkBg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel Orientation="Horizontal" Margin="20,10">
                                <Image Source="{Binding IconPath}" Width="25"/>
                                <TextBlock Text="{Binding Title}" Foreground="White" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="20">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AddBtn" Content="Добавить" Style="{StaticResource PrimaryBtn}"/>
                <TextBox Width="250" Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PlaceholderSearch}" VerticalAlignment="Center" Margin="10 0"/>
                <Button x:Name="FilterBtn" Style="{StaticResource PrimaryBtn}" Content="Фильтр"/>
                </StackPanel>
                <Button x:Name="ClearBtn" Content="Очистить" Style="{StaticResource SecondaryBtn}" ToolTip="Очистить параметры поиска и вывести весь список" HorizontalAlignment="Right"/>
            </DockPanel>

            <ContentControl x:Name="MainConteiner" Grid.Row="1" Margin="20 0 20 20"/>
        </Grid>
    </Grid>
</Window>
