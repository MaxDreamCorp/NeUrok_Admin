<UserControl x:Class="NeUrokAdmin.WPF.Views.UserControls.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="FilterBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFiltering, UpdateSourceTrigger=PropertyChanged}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource LightYellow}" />
                    <Setter Property="BorderThickness" Value="4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0 10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddBtn" 
                        Content="Добавить" 
                        Style="{StaticResource PrimaryBtn}"
                        Click="AddBtn_Click"/>
                <TextBox Width="250" 
                         Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource PlaceholderSearch}" 
                         VerticalAlignment="Center" 
                         Margin="10 10"
                         TextChanged="TextBox_TextChanged"/>
                <Button x:Name="FilterBtn" 
                        Style="{StaticResource FilterBtnStyle}" 
                        Content="Фильтр"
                        Click="FilterBtn_Click"/>
            </StackPanel>
            <Button x:Name="ClearBtn" 
                    Content="Очистить" 
                    Style="{StaticResource SecondaryBtn}" 
                    ToolTip="Очистить параметры поиска и вывести весь список" 
                    HorizontalAlignment="Right"
                    Click="ClearBtn_Click"/>
        </DockPanel>
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding DisplayedStudents}" 
                  Style="{StaticResource MainDataGridStyle}"
                 AutoGenerateColumns="False" 
          CanUserAddRows="False"
                  IsReadOnly="True"
          RowDetailsVisibilityMode="VisibleWhenSelected"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО студента" 
                            Binding="{Binding Client.ChildFullname}" 
                            Width="*"/>
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F0F4F7" Padding="5" BorderBrush="#D1D1D1" BorderThickness="0,1,0,1">
                        <StackPanel>
                            <TextBlock Text="Активные абонементы:" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10" 
                               Foreground="#2C3E50"/>

                            <DataGrid ItemsSource="{Binding StudentSubscriptions}" 
                                      Style="{StaticResource MainDataGridStyle}"
                                      BorderThickness="1"
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Окончание" Binding="{Binding FinishDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Курс" Binding="{Binding Course.Name}" Width="Auto"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding SubscriptionStatus.Status}" Width="Auto"/>
                                    <DataGridTextColumn Header="Тип занятий" Binding="{Binding ClassesType.Type}" Width="Auto"/>
                                    <DataGridTextColumn Header="Кол-во занятий" Binding="{Binding ClassesAmount}" Width="Auto"/>
                                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost, StringFormat='{}{0:N2} ₽'}" Width="Auto"/>
                                    <DataGridCheckBoxColumn Header="Оплачен" Binding="{Binding IsPaid}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </Grid>
</UserControl>