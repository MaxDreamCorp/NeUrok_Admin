<UserControl x:Class="NeUrokAdmin.WPF.Views.UserControls.GroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.UserControls"
             xmlns:helpers="clr-namespace:NeUrokAdmin.WPF.Helpers"
             mc:Ignorable="d" 
                      Loaded="UserControl_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="FilterBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFiltering, UpdateSourceTrigger=PropertyChanged}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource LightYellow}" />
                    <Setter Property="BorderThickness" Value="4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0 10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddBtn" 
                        Content="Добавить" 
                        Style="{StaticResource PrimaryBtn}"
                        Click="AddBtn_Click"/>
                <TextBox Width="250" 
                         Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource PlaceholderSearch}" 
                         VerticalAlignment="Center" 
                         Margin="10 10"
                         TextChanged="TextBox_TextChanged"/>
                <Button x:Name="FilterBtn" 
                        Style="{StaticResource FilterBtnStyle}" 
                        Content="Фильтр"
                        Click="FilterBtn_Click"/>
            </StackPanel>
            <Button x:Name="ClearBtn" 
                    Content="Очистить" 
                    Style="{StaticResource SecondaryBtn}" 
                    ToolTip="Очистить параметры поиска и вывести весь список" 
                    HorizontalAlignment="Right"
                    Click="ClearBtn_Click"/>
        </DockPanel>
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding DisplayedGroups}" 
                  Style="{StaticResource MainDataGridStyle}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" 
                  IsReadOnly="True"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">
            <DataGrid.Resources>
                <Style TargetType="TextBlock" x:Key="WrapStyle">
                    <Setter Property="TextWrapping" Value="Wrap"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding Id}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Название группы" 
                                    Binding="{Binding Name}" 
                                    ElementStyle="{StaticResource WrapStyle}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Курс" 
                                    Binding="{Binding Course.Name}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Педагог" 
                                    Binding="{Binding Teacher.Fullname}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Статус" 
                                    Binding="{Binding GroupStatus.Status}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Дни недели" 
                                    Binding="{Binding WeekDays}" 
                                    Width="Auto"/>
               
                <DataGridTextColumn Header="Время" 
                                    Binding="{Binding Time, StringFormat='HH:mm'}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Занятий" 
                                    Binding="{Binding ClassesCount}" 
                                    Width="Auto"/>
                <DataGridTextColumn Header="Учеников" 
                                    Binding="{Binding StudentCount}" 
                                    Width="Auto"/>
               
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#F0F4F7" Padding="5" BorderBrush="#D1D1D1" BorderThickness="0,1,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="10">
                                <TextBlock Text="Ученики:" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10" 
                       Foreground="#2C3E50"/>

                                <DataGrid ItemsSource="{Binding Students}" 
                              Style="{StaticResource MainDataGridStyle}"
                              BorderThickness="1"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                                        <DataGridTextColumn Header="ФИО" Binding="{Binding Client.ChildFullname}" Width="Auto"/>
                                      
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                              <StackPanel Margin="10" Grid.Column="1">
                                <TextBlock Text="Занятия:" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10" 
                       Foreground="#2C3E50"/>

                                <Calendar SelectionMode="MultipleRange"
                                          HorizontalAlignment="Left"
                                          helpers:CalendarHelper.BindableSelectedDates="{Binding Dates}"
                                        x:Name="DatesCalendar"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </Grid>
</UserControl>
