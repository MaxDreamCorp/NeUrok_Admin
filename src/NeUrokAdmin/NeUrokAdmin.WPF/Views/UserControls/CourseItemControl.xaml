<UserControl x:Class="NeUrokAdmin.WPF.Views.UserControls.CourseItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.UserControls"
             mc:Ignorable="d" 
             MinWidth="200">
    <Grid>
        <ListBox Grid.Row="1"
          ItemsSource="{Binding FilteredItems}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Data.Id}"/>
                <TextBlock Text="{Binding Data.Name}" Margin="10,0"/>
            </StackPanel>
        </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
    </Grid>
</UserControl>
