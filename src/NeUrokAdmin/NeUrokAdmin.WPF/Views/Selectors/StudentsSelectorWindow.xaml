<Window x:Class="NeUrokAdmin.WPF.Views.Selectors.StudentsSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.Selectors"
        mc:Ignorable="d"
                Title="Ученики" 
        Loaded="Window_Loaded"
        MinHeight="650" 
        MinWidth="700"
        SizeToContent="WidthAndHeight">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button x:Name="BackBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Назад"
                    HorizontalAlignment="Left"
                    Click="BackBtn_Click"/>
            <TextBox Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource PlaceholderSearch}"
                     Margin="10"
                     HorizontalAlignment="Center"
                     MinWidth="250"
                     TextChanged="QuickSearchInp_TextChanged"/>
            <Button x:Name="AddBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Создать"
                    Margin="10 0"
                    HorizontalAlignment="Right"
                    Click="AddBtn_Click"/>
            <Button x:Name="SelectBtn"
                    Style="{StaticResource PrimaryBtn}"
                    Content="Выбрать"
                    HorizontalAlignment="Right"
                    Click="SelectBtn_Click"/>
        </DockPanel>

        <ListBox x:Name="StudentList"
         ItemsSource="{Binding FilteredStudents}"
                 Grid.Row="1"
         HorizontalContentAlignment="Stretch"
         BorderThickness="0"
         Background="Transparent">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White" Margin="2">
                        <Expander IsExpanded="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                          Background="Transparent"
                          BorderThickness="0">

                            <Expander.Header>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                  Checked="CheckBox_Checked"
                                  VerticalContentAlignment="Center"
                                  Margin="5,0">
                                    <Grid Margin="10,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Student.Id, StringFormat='ID: {0}'}" 
                                           Foreground="#888" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" Text="{Binding Student.Client.ChildFullname}" 
                                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    </Grid>
                                </CheckBox>
                            </Expander.Header>

                            <Border BorderBrush="#EEE" BorderThickness="0,1,0,0" Background="#FAFAFA" Padding="15,10,10,10">
                                <StackPanel>
                                    <TextBlock Text="Абонементы студента" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#555"/>

                                    <DataGrid ItemsSource="{Binding Student.StudentSubscriptions}" 
                                                   Style="{StaticResource MainDataGridStyle}"
                                                   BorderThickness="1"
                                           AutoGenerateColumns="False" 
                                           CanUserAddRows="False"
                                           IsReadOnly="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                                            <DataGridTextColumn Header="Окончание" Binding="{Binding FinishDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto"/>
                                            <DataGridTextColumn Header="Курс" Binding="{Binding Course.Name}" Width="Auto"/>
                                            <DataGridTextColumn Header="Статус" Binding="{Binding SubscriptionStatus.Status}" Width="Auto"/>
                                            <DataGridTextColumn Header="Тип занятий" Binding="{Binding ClassesType.Type}" Width="Auto"/>
                                            <DataGridTextColumn Header="Кол-во занятий" Binding="{Binding ClassesAmount}" Width="Auto"/>
                                            <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost, StringFormat='{}{0:N2} ₽'}" Width="Auto"/>
                                            <DataGridCheckBoxColumn Header="Оплачен" Binding="{Binding IsPaid}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Window>
