<Window x:Class="NeUrokAdmin.WPF.Views.Selectors.ClientsSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.Selectors"
        mc:Ignorable="d"
        Title="Клиенты" 
        Loaded="Window_Loaded"
        MinHeight="650" 
        MinWidth="700"
        SizeToContent="WidthAndHeight">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button x:Name="BackBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Назад"
                    HorizontalAlignment="Left"
                    Click="BackBtn_Click"/>
            <TextBox x:Name="QuickSearchInp" Style="{StaticResource PlaceholderSearch}"
                     Margin="10"
                     HorizontalAlignment="Center"
                     MinWidth="250"
                     TextChanged="QuickSearchInp_TextChanged"/>
            <Button x:Name="AddBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Создать"
                    Margin="10 0"
                    HorizontalAlignment="Right"
                    Click="AddBtn_Click"/>
            <Button x:Name="SelectBtn"
                    Style="{StaticResource PrimaryBtn}"
                    Content="Выбрать"
                    HorizontalAlignment="Right"
                    Click="SelectBtn_Click"/>
        </DockPanel>

        <ListBox x:Name="ClientList"
         Grid.Row="1"
         ItemsSource="{Binding FilteredClients}"
         HorizontalContentAlignment="Stretch"
         BorderThickness="0"
         Background="Transparent">
            <ListBox.ItemContainerStyle>

                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD" 
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Background="White" 
                    Padding="10">

                        <CheckBox IsChecked="{Binding IsSelected}"
                          Checked="CheckBox_Checked"
                          VerticalContentAlignment="Top">

                            <Grid Margin="10,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Client.Id, StringFormat='ID: {0}'}" 
                                       FontWeight="Bold" Foreground="#666"/>
                                        <TextBlock Text="{Binding Client.RegistrationDate,StringFormat=\{0:dd.MM.yyyy\}}" 
                                        FontSize="10" Foreground="#888"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Client.ChildFullname}" 
                                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Client.Grade, StringFormat='Класс: {0}'}" FontSize="11" Margin="0,0,8,0"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Дата рожд.:" FontSize="11" Foreground="#555" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Client.BirthDate, StringFormat=\{0:dd.MM.yyyy\}}" FontSize="11" Foreground="#555"/>
                                    </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="5,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Client.ParentName}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Client.Phone}" Foreground="#2E7D32"/>
                                    <TextBlock Text="{Binding Client.AdditionalPhones}" FontSize="10" TextWrapping="Wrap" Foreground="#777"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="5,0" VerticalAlignment="Top">
                                    <Border Background="#E3F2FD" CornerRadius="10" HorizontalAlignment="Left" Padding="8,2">
                                        <TextBlock Text="{Binding Client.Status.Status}" FontSize="11" Foreground="#1976D2"/>
                                    </Border>
                                    <TextBlock Text="{Binding Client.WishedCoursesDisplay}" 
                                       Margin="0,4,0,0"
                                       FontSize="11" 
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Foreground="#444"/>
                                </StackPanel>

                                <TextBlock Grid.Column="4" 
                                   Text="{Binding Client.Notes}" 
                                   TextWrapping="Wrap" 
                                   FontSize="11" 
                                   Foreground="#666"
                                   FontStyle="Italic"
                                   Margin="10,0,0,0"/>
                            </Grid>
                        </CheckBox>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Window>
