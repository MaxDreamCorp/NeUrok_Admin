<Window x:Class="NeUrokAdmin.WPF.Views.Selectors.SubscriptionsSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.Selectors"
        mc:Ignorable="d"
        Title="Абонементы" 
        Loaded="Window_Loaded"
        MinHeight="650" 
        MinWidth="550"
        SizeToContent="WidthAndHeight">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button x:Name="BackBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Назад"
                    HorizontalAlignment="Left"
                    Click="BackBtn_Click"/>
            <TextBox x:Name="QuickSearchInp" Style="{StaticResource PlaceholderSearch}"
                     Margin="10"
                     HorizontalAlignment="Center"
                     MinWidth="250"
                     TextChanged="QuickSearchInp_TextChanged"/>
            <Button x:Name="AddBtn"
                    Style="{StaticResource SecondaryBtn}"
                    Content="Создать"
                    Margin="10 0"
                    HorizontalAlignment="Right"
                    Click="AddBtn_Click"/>
            <Button x:Name="SelectBtn"
                    Style="{StaticResource PrimaryBtn}"
                    Content="Выбрать"
                    HorizontalAlignment="Right"
                    Click="SelectBtn_Click"/>
        </DockPanel>

        <ListBox x:Name="SubscriptionList"
         ItemsSource="{Binding FilteredSubscriptions}"
         HorizontalContentAlignment="Stretch"
         Background="Transparent"
                 Grid.Row="1"
         BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="3"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <EventSetter Event="MouseDoubleClick" Handler="ListBoxItem_MouseDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Background="White" 
                    Padding="10">
                        <CheckBox IsChecked="{Binding IsSelected}"
                          Checked="CheckBox_Checked"
                          VerticalContentAlignment="Center">
                            <Grid Margin="10,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Margin="5 0"
                                   Text="{Binding Subscription.Id, StringFormat='ID: {0}'}" 
                                   Foreground="#9E9E9E" 
                                   VerticalAlignment="Center"
                                   FontSize="11"/>

                                <StackPanel Grid.Column="1"
                                            Margin="5 0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Subscription.Name}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Subscription.ClassesType.Name}" 
                                       FontSize="11" 
                                       Foreground="#1976D2"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center" 
                                            Margin="5 0"
                                    VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Subscription.ClassesAmount}" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#455A64"/>
                                    <TextBlock Text=" зан." 
                                       FontSize="12" 
                                       VerticalAlignment="Bottom" 
                                       Margin="2,0,0,2"
                                       Foreground="#78909C"/>
                                </StackPanel>

                                <Border Grid.Column="3" 
                                Background="#F1F8E9" 
                                CornerRadius="4" 
                                Padding="8,4" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Subscription.Cost, StringFormat='{}{0:N0} ₽'}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Foreground="#388E3C"/>
                                </Border>
                            </Grid>
                        </CheckBox>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Window>
