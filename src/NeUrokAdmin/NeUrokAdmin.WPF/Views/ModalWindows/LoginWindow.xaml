<Window x:Class="NeUrokAdmin.WPF.Views.ModalWindows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.ModalWindows"
        mc:Ignorable="d"
        Title="LoginWindow"
        MinWidth="350"
        SizeToContent="WidthAndHeight">
    <Grid Margin="10">
        <StackPanel Margin="30 15">
            <Image Source="/Resources/Icons/LogoIcon.png"
            Width="87"
            RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Добро пожаловать!"
                FontFamily="Calibri"
                FontWeight="Bold"
                FontSize="26"
                HorizontalAlignment="Center"
                Margin="0,20,0,10"/>
            <StackPanel>
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource PlaceholderTextBoxStyle}"/>

                <Grid Style="{StaticResource PasswordWithPlaceholderStyle}">
                    <PasswordBox x:Name="PassInp" 
                     Style="{StaticResource PlaceholderPasswordBoxStyle}"/>
                    <TextBlock x:Name="placeholderText" 
                       Text="Пароль"
                       FontSize="14"
                       Foreground="Gray"
                       Margin="7 15"
                       FontStyle="Italic"       
                       IsHitTestVisible="False" 
                       VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <StackPanel>
                <Button Style="{StaticResource PrimaryBtn}" 
                        Content="Войти"
                        Command="{Binding LogInCommand}"
                        CommandParameter="{Binding ElementName=PassInp}"/>
                <Button Style="{StaticResource SecondaryBtn}" 
                        Content="Зарегистрироваться" 
                        Margin="0 10"
                        Command="{Binding RegistrationCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
