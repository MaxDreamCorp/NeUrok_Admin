<Window x:Class="NeUrokAdmin.WPF.Views.ModalWindows.MultiplySelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NeUrokAdmin.WPF.Views.Elements.ViewModels"
        xmlns:models="clr-namespace:NeUrokAdmin.Domain.DTOs;assembly=NeUrokAdmin.Domain"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.ModalWindows" xmlns:ctrls="clr-namespace:NeUrokAdmin.WPF.Views.UserControls"
        mc:Ignorable="d"
        Title="{Binding Title}" 
        MinHeight="450" 
        MinWidth="400"
        SizeToContent="WidthAndHeight">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" /> 
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button Style="{StaticResource SecondaryBtn}"
                    Content="Назад"
                    HorizontalAlignment="Left"
                    Command="{Binding BackCommand}"/>
            <TextBox Style="{StaticResource PlaceholderSearch}"
                     Margin="10"
                     HorizontalAlignment="Center"
                     MinWidth="250"
                     Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Style="{StaticResource PrimaryBtn}"
                    Content="Выбрать"
                    HorizontalAlignment="Right"
                    Command="{Binding SelectCommand}"/>
        </DockPanel>

        <ContentControl Grid.Row="1" 
                 Margin="0 10"
                 Content="{Binding CurrentSelector}"/>
    </Grid>
</Window>
