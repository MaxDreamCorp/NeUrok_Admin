<Window x:Class="NeUrokAdmin.WPF.Views.CardWindows.SubscriptionCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.CardWindows"
        mc:Ignorable="d"
        Width="500"
        SizeToContent="Height"
        Loaded="Window_Loaded"
        Title="Абонемент">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">
            <Button x:Name="BackBtn" 
                    Style="{StaticResource SecondaryBtn}" 
                    Content="Назад"
                    Click="BackBtn_Click"/>
            <TextBlock Style="{StaticResource HeaderText}"
                       Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}"
                       Margin="10 0 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" 
                    Margin="0 10">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <TextBlock Text="ID:" 
                           Grid.Row="0" 
                           Style="{StaticResource CardTextBlock}"
                           Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />
                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="0" 
                         Grid.Column="1" 
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />

                <GroupBox Grid.Row="1"
                          Grid.Column="1"
                          Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="От:"
                                Style="{StaticResource CardTextBlock}" Margin="0,5,10,5"/>
                        <ComboBox Text="{Binding IdFrom, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                  ItemsSource="{Binding Ids, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"
                                  HorizontalAlignment="Left"
                                  Width="80"
                                  Margin="0 5 0 0"
                                  FontSize="13"/>   
                        <TextBlock Text="До:"
                                   Margin=" 15 0"
                                   Style="{StaticResource CardTextBlock}"/>
                        <ComboBox Text="{Binding IdTo, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                   ItemsSource="{Binding Ids, UpdateSourceTrigger=PropertyChanged}"
                                   IsEditable="True"
                                   StaysOpenOnEdit="True"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0 5 0 0"
                                   FontSize="13"/>                      
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="Название:" 
                           Grid.Row="2" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="2" 
                         Grid.Column="1" 
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Тип занятий:" 
                            Grid.Row="3" 
                            Style="{StaticResource CardTextBlock}"/>
                <ComboBox SelectedItem="{Binding ClassesType, UpdateSourceTrigger=PropertyChanged}" 
                           ItemsSource="{Binding ClassesTypes, UpdateSourceTrigger=PropertyChanged}" 
                           Style="{StaticResource ModernComboBox}"
                           Grid.Row="3" 
                           Grid.Column="1" 
                           Margin="0,5" 
                           IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <GroupBox Grid.Row="4"
                            Grid.Column="1"
                            Margin="0 5"
                            Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Типы занятий:" 
                                    Style="{StaticResource CardTextBlock}"/>
                        <TextBox Text="{Binding SearchingClassesTypesDisplay}"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,5" 
                                 Style="{StaticResource Tbox}" 
                                 IsReadOnly="True"/>
                        <Button x:Name="SelectClassesTypesBtn" 
                                Content="Выбрать типы"
                                Style="{StaticResource MiniSecondaryBtn}"
                                HorizontalAlignment="Right"
                                Click="SelectClassesTypesBtn_Click"/>
                    </StackPanel>
                </GroupBox>
                
                <TextBlock Text="Стоимость:" 
                            Grid.Row="5" 
                            Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="5" 
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource Tbox}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <GroupBox Grid.Row="6"
                           Grid.Column="1"
                           Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="От:"
                                    Style="{StaticResource CardTextBlock}" Margin="0,5,10,5"/>
                        <TextBox Text="{Binding CostFrom, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                   Style="{StaticResource Tbox}"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0 5 0 0"
                                   FontSize="13"/>
                        <TextBlock Text="До:"
                                    Margin=" 15 0"
                                    Style="{StaticResource CardTextBlock}"/>
                        <TextBox Text="{Binding CostTo, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                   Style="{StaticResource Tbox}"
                                   HorizontalAlignment="Left"
                                   Width="80"
                                   Margin="0 5 0 0"
                                   FontSize="13"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="Кол-во занятий:" 
                            Grid.Row="7" 
                            Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding ClassesAmount, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="7" 
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource Tbox}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <GroupBox Grid.Row="8"
                         Grid.Column="1"
                         Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="От:"
                                    Style="{StaticResource CardTextBlock}" Margin="0,5,10,5"/>
                        <TextBox Text="{Binding ClassesAmountFrom, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Tbox}"
                                 HorizontalAlignment="Left"
                                 Width="80"
                                 Margin="0 5 0 0"
                                 FontSize="13"/>
                        <TextBlock Text="До:"
                                    Margin=" 15 0"
                                    Style="{StaticResource CardTextBlock}"/>
                        <TextBox Text="{Binding ClassesAmountTo, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Tbox}"
                                 HorizontalAlignment="Left"
                                 Width="80"
                                 Margin="0 5 0 0"
                                 FontSize="13"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </StackPanel>

        <DockPanel Grid.Row="2">
            <Button x:Name="DelBtn" 
                    Style="{StaticResource DangerBtn}" 
                    HorizontalAlignment="Left"
                    Content="Удалить"
                    IsEnabled="{Binding IsDeletable, UpdateSourceTrigger=PropertyChanged}"
                    Click="DelBtn_Click"/>
            <Button x:Name="AcceptBtn" 
                    Style="{StaticResource PrimaryBtn}" 
                    HorizontalAlignment="Right"
                    Content="Подтвердить"
                    Click="AcceptBtn_Click"/>
        </DockPanel>
    </Grid>
</Window>
