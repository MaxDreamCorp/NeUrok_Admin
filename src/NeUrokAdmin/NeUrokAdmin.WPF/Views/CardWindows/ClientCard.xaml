<Window x:Class="NeUrokAdmin.WPF.Views.CardWindows.ClientCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.CardWindows"
        mc:Ignorable="d"
        MinWidth="500"
        MaxWidth="500"
        Height="620"
        Loaded="Window_Loaded"
        Title="Клиент">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">
            <Button x:Name="BackBtn" 
                    Style="{StaticResource SecondaryBtn}" 
                    Content="Назад"
                    Click="BackBtn_Click"/>
            <TextBlock Style="{StaticResource HeaderText}"
                       Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}"
                       Margin="10 0 0 0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                    Margin="0 10">
            <StackPanel>
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ID:" 
                           Grid.Row="0" 
                           Style="{StaticResource CardTextBlock}"
                           Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />
                    <TextBox Text="{Binding Id, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="0" 
                         Grid.Column="1" 
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />


                    <GroupBox Grid.Row="1"
                            Grid.Column="1"
                            Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="От:"
                               Style="{StaticResource CardTextBlock}" Margin="0,5,10,5"/>
                            <ComboBox Text="{Binding IdFrom, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                            ItemsSource="{Binding Ids, UpdateSourceTrigger=PropertyChanged}"
                            IsEditable="True"
                            StaysOpenOnEdit="True"
                            HorizontalAlignment="Left"
                            Width="80"
                            Margin="0 5 0 0"
                            FontSize="13"/>
                            <TextBlock Text="До:"
                                   Margin=" 15 0"
                               Style="{StaticResource CardTextBlock}"/>
                            <ComboBox Text="{Binding IdTo, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                         ItemsSource="{Binding Ids, UpdateSourceTrigger=PropertyChanged}"
                         IsEditable="True"
                         StaysOpenOnEdit="True"
                         HorizontalAlignment="Left"
                         Width="80"
                         Margin="0 5 0 0"
                         FontSize="13"/>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock Text="ФИО:" 
                           Grid.Row="2" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding ChildFullname, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="2" 
                         Grid.Column="1"
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Дата рожд.:"
                           Grid.Row="3"
                           Style="{StaticResource CardTextBlock}"/>
                    <DatePicker SelectedDate="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="3"
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource DatePicker}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <GroupBox Grid.Row="4"
                            Grid.Column="1"
                            Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="От:"
                               Style="{StaticResource CardTextBlock}" VerticalAlignment="Center" />
                                <DatePicker SelectedDate="{Binding BirthDateFrom, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0 5"
                                Style="{StaticResource DatePicker}"/>
                                <TextBlock Text="До:"
                               Style="{StaticResource CardTextBlock}" Margin="15 0"/>
                                <DatePicker SelectedDate="{Binding BirthDateTo, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0 5"
                                                    Style="{StaticResource DatePicker}"/>
                            </StackPanel>
                            <TextBlock Text="По oтдельности:"
                               Style="{StaticResource CardTextBlock}" />



                            <StackPanel Orientation="Horizontal">
                                <ComboBox SelectedItem="{Binding BirthDateDay, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                  ItemsSource="{Binding Days, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"
                                  Width="80"
                                  Margin="0,0,15,0"
                                  FontSize="13"/>
                                <ComboBox SelectedItem="{Binding BirthDateMonth, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                  ItemsSource="{Binding Months, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"
                                  Width="80"
                                  Margin="0,0,15,0"
                                  FontSize="13"/>
                                <ComboBox SelectedItem="{Binding BirthDateYear, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                  ItemsSource="{Binding Years, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"
                                  Width="120"
                                  Margin="0,0,15,0"
                                  FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <TextBlock Text="Дата рег.:"
                           Grid.Row="5" 
                           Style="{StaticResource CardTextBlock}"/>
                    <DatePicker SelectedDate="{Binding RegistrationDate, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="5"
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource DatePicker}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>


                    <StackPanel Grid.Row="6"
                            Grid.Column="1"
                            Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="От:"
             Style="{StaticResource CardTextBlock}" />
                            <DatePicker SelectedDate="{Binding RegistrationDateFrom, UpdateSourceTrigger=PropertyChanged}"
               Style="{StaticResource DatePicker}" Margin="0,5,0,5"/>
                            <TextBlock Text="До:"
             Style="{StaticResource CardTextBlock}" Margin="15 0"/>
                            <DatePicker SelectedDate="{Binding RegistrationDateTo, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0 5"
                                   Style="{StaticResource DatePicker}"/>
                        </StackPanel>
                        <TextBlock Text="По oтдельности:"
             Style="{StaticResource CardTextBlock}" Margin="0,0,10,5"/>

                        <StackPanel Orientation="Horizontal">
                            <ComboBox SelectedItem="{Binding RegistrationDateDay, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                 ItemsSource="{Binding Days, UpdateSourceTrigger=PropertyChanged}"
                 IsEditable="True"
                 StaysOpenOnEdit="True"
                 Width="80"
                 Margin="0,0,15,0"
                 FontSize="13"/>
                            <ComboBox SelectedItem="{Binding RegistrationDateMonth, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                 ItemsSource="{Binding Months, UpdateSourceTrigger=PropertyChanged}"
                 IsEditable="True"
                 StaysOpenOnEdit="True"
                 Width="80"
                 Margin="0,0,15,0"
                 FontSize="13"/>
                            <ComboBox SelectedItem="{Binding RegistrationDateYear, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                 ItemsSource="{Binding Years, UpdateSourceTrigger=PropertyChanged}"
                 IsEditable="True"
                 StaysOpenOnEdit="True"
                 Width="120"
                 Margin="0,0,15,0"
                 FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Класс:"
                           Grid.Row="7" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding Grade, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="7"
                         Grid.Column="1" 
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <GroupBox Grid.Row="8"
                          Grid.Column="1"
                          Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">


                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="От:"
                             Style="{StaticResource CardTextBlock}" Margin="0,5,10,5"/>
                            <ComboBox SelectedItem="{Binding GradeFrom, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                ItemsSource="{Binding Grades, UpdateSourceTrigger=PropertyChanged}"
                                IsEditable="True"
                                StaysOpenOnEdit="True"
                                HorizontalAlignment="Left"
                                Width="80"
                                Margin="0,5,0,5"
                                FontSize="13"/>
                            <TextBlock Text="До:"
                             Style="{StaticResource CardTextBlock}" Margin="10,5,10,5"/>
                            <ComboBox SelectedItem="{Binding GradeTo, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                                ItemsSource="{Binding Grades, UpdateSourceTrigger=PropertyChanged}"
                                IsEditable="True"
                                StaysOpenOnEdit="True"
                                HorizontalAlignment="Left"
                                Width="80"
                                Margin="0 5 15 5"
                                FontSize="13"/>
                        </StackPanel>
                    </GroupBox>
                    <TextBlock Text="Статус:" 
                           Grid.Row="9" 
                           Style="{StaticResource CardTextBlock}"/>
                    <ComboBox SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}" 
                          ItemsSource="{Binding ClientStatuses, UpdateSourceTrigger=PropertyChanged}" 
                          Style="{StaticResource ModernComboBox}"
                          Grid.Row="9" 
                          Grid.Column="1" 
                          Margin="0,5" 
                          IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <GroupBox Grid.Row="10"
                            Grid.Column="1"
                            Margin="0 5"
                            Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Статусы:" 
                               Style="{StaticResource CardTextBlock}"/>
                            <TextBox Text="{Binding SearchingStatusesDisplay}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,5" 
                             Style="{StaticResource Tbox}" 
                             IsReadOnly="True"/>
                            <Button x:Name="SelectSearchingStatusesBtn" 
                            Content="Выбрать статусы"
                            Style="{StaticResource MiniSecondaryBtn}"
                            HorizontalAlignment="Right"
                                    Click="SelectSearchingStatusesBtn_Click"/>
                        </StackPanel>
                    </GroupBox>
                    <TextBlock Text="Родитель:" 
                           Grid.Row="11" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding ParentName, TargetNullValue=''}" 
                         Grid.Row="11" 
                         Grid.Column="1" 
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Телефон:" 
                           Grid.Row="12" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding Phone, TargetNullValue=''}" 
                         Grid.Row="12"
                         Grid.Column="1"
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Доп. связь:" 
                           Grid.Row="13" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding AdditionalPhone, TargetNullValue=''}" 
                         Grid.Row="13"
                         Grid.Column="1" 
                         Margin="0,5" 
                         TextWrapping="Wrap" 
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <StackPanel>
                    <TextBlock Text="Желаемые курсы:" 
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding WishedCoursesDisplay}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,5" 
                         Style="{StaticResource Tbox}" 
                         IsReadOnly="True" 
                         MinHeight="60"/>
                    <Button x:Name="SelectCoursesBtn" 
                        Content="Выбрать курсы"
                        Style="{StaticResource MiniSecondaryBtn}"
                        HorizontalAlignment="Right"
                        Click="SelectCoursesBtn_Click"/>

                    <TextBlock Text="Заметки:"
                           Style="{StaticResource CardTextBlock}"/>
                    <TextBox Text="{Binding Notes, TargetNullValue=''}" 
                         Style="{StaticResource Tbox}"
                         MinHeight="60" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                        IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    <DockPanel Grid.Row="2">
        <Button x:Name="DelBtn" 
               Style="{StaticResource DangerBtn}" 
               HorizontalAlignment="Left"
               Content="Удалить"
               IsEnabled="{Binding IsDeletable, UpdateSourceTrigger=PropertyChanged}"
               Click="DelBtn_Click"/>
        <Button x:Name="AcceptBtn" 
               Style="{StaticResource PrimaryBtn}" 
               HorizontalAlignment="Right"
               Content="Подтвердить"
               Click="AcceptBtn_Click"/>
    </DockPanel>
    </Grid>
</Window>
