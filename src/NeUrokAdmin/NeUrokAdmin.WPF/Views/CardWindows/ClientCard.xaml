<Window x:Class="NeUrokAdmin.WPF.Views.CardWindows.ClientCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.CardWindows"
             mc:Ignorable="d"  Background="White"
             MinWidth="480"
             SizeToContent="WidthAndHeight"
             Loaded="Window_Loaded"
             Title="Клиент">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
               Orientation="Horizontal">
            <Button x:Name="BackBtn" 
               Style="{StaticResource SecondaryBtn}" 
               Content="Назад"
               Click="BackBtn_Click"/>
            <TextBlock Style="{StaticResource HeaderText}"
                  Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}"
                  Margin="10 0 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0 10">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ФИО:" Grid.Row="0" Margin="0,5,10,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Text="{Binding ChildFullname, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="0" Grid.Column="1" Margin="0,5" Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Дата рожд.:" Grid.Row="1" Margin="0,5,10,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <DatePicker SelectedDate="{Binding BirthDate, TargetNullValue={x:Null}}" 
                            Grid.Row="1" Grid.Column="1" Margin="0,5" Style="{StaticResource DatePicker}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Класс:" Grid.Row="2" Margin="0,5,10,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Grade, TargetNullValue=''}" 
                         Grid.Row="2" Grid.Column="1" Margin="0,5"  Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Статус:" Grid.Row="3" Margin="0,5,10,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox Text="{Binding Status.Name, Mode=OneWay, TargetNullValue='Не указан'}" 
                          ItemsSource="{Binding ClientStatuses, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernComboBox}"
                         Grid.Row="3" Grid.Column="1" Margin="0,5" IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Родитель:" Grid.Row="4" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding ParentName, TargetNullValue=''}" 
                         Grid.Row="4" Grid.Column="1" Margin="0,5" Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Телефон:" Grid.Row="5" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Phone, TargetNullValue=''}" 
                         Grid.Row="5" Grid.Column="1" Margin="0,5" Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Доп. связь:" Grid.Row="6" Margin="0,5,10,5" FontWeight="SemiBold"/>
                <TextBox Text="{Binding AdditionalPhones, TargetNullValue=''}" 
                         Grid.Row="6" Grid.Column="1" Margin="0,5" TextWrapping="Wrap" AcceptsReturn="True"  Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <StackPanel>
                <TextBlock Text="Желаемые курсы:" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBlock Text="{Binding WishedCoursesDisplay}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <Button x:Name="SelectCoursesBtn" Content="Выбрать курсы" Width="200" Style="{StaticResource SecondaryBtn}" Click="SelectCoursesBtn_Click"/>

                <TextBlock Text="Заметки:" FontWeight="Bold" Margin="0,5,0,2"/>
                <TextBox Text="{Binding Client.Notes, TargetNullValue=''}" Style="{StaticResource Tbox}"
                     MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"
                     IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </StackPanel>

    <DockPanel Grid.Row="2">
        <Button x:Name="DelBtn" 
               Style="{StaticResource DangerBtn}" 
               HorizontalAlignment="Left"
               Content="Удалить"
               IsEnabled="{Binding IsDeletable, UpdateSourceTrigger=PropertyChanged}"
               Click="DelBtn_Click"/>
        <Button x:Name="AcceptBtn" 
               Style="{StaticResource PrimaryBtn}" 
               HorizontalAlignment="Right"
               Content="Подтвердить"
               Click="AcceptBtn_Click"/>
    </DockPanel>
    </Grid>
</Window>
