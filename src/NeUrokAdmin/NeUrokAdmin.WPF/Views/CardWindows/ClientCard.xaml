<Window x:Class="NeUrokAdmin.WPF.Views.CardWindows.ClientCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.CardWindows"
        mc:Ignorable="d"
        MinWidth="500"
        MaxWidth="500"
        SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded"
        Title="Клиент">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">
            <Button x:Name="BackBtn" 
                    Style="{StaticResource SecondaryBtn}" 
                    Content="Назад"
                    Click="BackBtn_Click"/>
            <TextBlock Style="{StaticResource HeaderText}"
                       Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}"
                       Margin="10 0 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" 
                    Margin="0 10">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ID:" 
                           Grid.Row="0" 
                           Style="{StaticResource CardTextBlock}"
                           Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />
                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="0" 
                         Grid.Column="1" 
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         Visibility="{Binding IsFilter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="ФИО:" 
                           Grid.Row="1" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding ChildFullname, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="1" 
                         Grid.Column="1"
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Дата рожд.:"
                           Grid.Row="2" 
                           Style="{StaticResource CardTextBlock}"/>
                <DatePicker SelectedDate="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="2"
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource DatePicker}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Дата рег.:"
                           Grid.Row="3" 
                           Style="{StaticResource CardTextBlock}"/>
                <DatePicker SelectedDate="{Binding RegistrationDate, UpdateSourceTrigger=PropertyChanged}" 
                            Grid.Row="3"
                            Grid.Column="1" 
                            Margin="0,5" 
                            Style="{StaticResource DatePicker}"
                            IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Класс:"
                           Grid.Row="4" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding Grade, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="4"
                         Grid.Column="1" 
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Статус:" 
                           Grid.Row="5" 
                           Style="{StaticResource CardTextBlock}"/>
                <ComboBox Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}" 
                          ItemsSource="{Binding ClientStatuses, UpdateSourceTrigger=PropertyChanged}" 
                          Style="{StaticResource ModernComboBox}"
                          Grid.Row="5" 
                          Grid.Column="1" 
                          Margin="0,5" 
                          IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Родитель:" 
                           Grid.Row="6" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding ParentName, TargetNullValue=''}" 
                         Grid.Row="6" 
                         Grid.Column="1" 
                         Margin="0,5"
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Телефон:" 
                           Grid.Row="7" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding Phone, TargetNullValue=''}" 
                         Grid.Row="7"
                         Grid.Column="1"
                         Margin="0,5" 
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Доп. связь:" 
                           Grid.Row="8" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding AdditionalPhone, TargetNullValue=''}" 
                         Grid.Row="8"
                         Grid.Column="1" 
                         Margin="0,5" 
                         TextWrapping="Wrap" 
                         Style="{StaticResource Tbox}"
                         IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <StackPanel>
                <TextBlock Text="Желаемые курсы:" 
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding WishedCoursesDisplay}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,5" 
                         Style="{StaticResource Tbox}" 
                         IsReadOnly="True" 
                         MinHeight="60"/>
                <Button x:Name="SelectCoursesBtn" 
                        Content="Выбрать курсы"
                        Width="120" 
                        Style="{StaticResource SecondaryBtn}"
                        Padding="0 4" 
                        HorizontalAlignment="Right"
                        Click="SelectCoursesBtn_Click"/>

                <TextBlock Text="Заметки:"
                           Style="{StaticResource CardTextBlock}"/>
                <TextBox Text="{Binding Notes, TargetNullValue=''}" 
                         Style="{StaticResource Tbox}"
                         MinHeight="60" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                        IsEnabled="{Binding IsEditable, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </StackPanel>

    <DockPanel Grid.Row="2">
        <Button x:Name="DelBtn" 
               Style="{StaticResource DangerBtn}" 
               HorizontalAlignment="Left"
               Content="Удалить"
               IsEnabled="{Binding IsDeletable, UpdateSourceTrigger=PropertyChanged}"
               Click="DelBtn_Click"/>
        <Button x:Name="AcceptBtn" 
               Style="{StaticResource PrimaryBtn}" 
               HorizontalAlignment="Right"
               Content="Подтвердить"
               Click="AcceptBtn_Click"/>
    </DockPanel>
    </Grid>
</Window>
