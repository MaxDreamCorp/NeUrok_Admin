<Window x:Class="NeUrokAdmin.WPF.Views.CardWindows.StandartCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeUrokAdmin.WPF.Views.CardWindows"
        mc:Ignorable="d"
        Title="{Binding Title}" MinWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal">
            <Button Style="{StaticResource SecondaryBtn}" 
                    Content="Назад"
                    Command="{Binding BackCommand}"/>
            <TextBlock Style="{StaticResource HeaderText}"
                       Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}"
                       Margin="10 0 0 0"/>
        </StackPanel>
        <ContentControl Grid.Row="1" 
                        Margin="0 10"
                        Content="{Binding CurrentCard}"/>
        <DockPanel Grid.Row="2">
            <Button Style="{StaticResource DangerBtn}" 
                    HorizontalAlignment="Left"
                    Content="Удалить"
                    IsEnabled="{Binding IsDeletable, UpdateSourceTrigger=PropertyChanged}"
                    Command="{Binding DeleteCommand}"/>
            <Button Style="{StaticResource PrimaryBtn}" 
                    HorizontalAlignment="Right"
                    Content="Подтвердить"
                    Command="{Binding OkCommand}"/>
        </DockPanel>
    </Grid>
</Window>
